{
  "manifest_version": 3,
  "name": "WenBot Companion",
  "version": "0.4.4",
  "description": "Add bonus-hunt slots to WenBot straight from your casino — live hunt HUD, break-even radar, smart slot autocomplete. Tracking only; never touches your casino account.",
  "permissions": ["storage"],
  "host_permissions": ["https://wenbot.gg/*"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "WenBot Companion",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://stake.com/*",
        "https://stake.us/*",
        "https://stake.bet/*",
        "https://stake.games/*",
        "https://gambulls.com/*",
        "https://shuffle.com/*",
        "https://roobet.com/*",
        "https://rainbet.com/*",
        "https://gamdom.com/*",
        "https://razed.com/*",
        "https://chips.gg/*",
        "https://degen.com/*",
        "https://thrill.com/*"
      ],
      "js": ["config.js", "content/overlay.js"],
      "css": ["content/overlay.css"],
      "run_at": "document_idle"
    }
  ]
}
