rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Moderator delegation helpers ─────────────────────────────────────────
    // Streamers can grant up to 2 mods dashboard access. Each mod's Firebase
    // user has a custom claim: { delegatedFor: [ownerUid1, ownerUid2, ...] }.
    // Reading the claim is free (lives on the JWT) — no Firestore get() needed.
    function isMod(uid) {
      return request.auth != null
          && request.auth.token.delegatedFor is list
          && (uid in request.auth.token.delegatedFor);
    }
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }
    function isOwnerOrMod(uid) {
      return isOwner(uid) || isMod(uid);
    }

    match /streamers/{uid} {
      allow read: if isOwnerOrMod(uid);

      // On CREATE — block billing fields and Kick identity fields from being
      // self-set. (Only the owner can create — mods don't create streamers
      // they moderate; the streamer signed up themselves.)
      // Also block modUids on create — owner can add mods later via the
      // server endpoint, not by hand.
      allow create: if isOwner(uid)
        && !request.resource.data.keys().hasAny([
          'plan',
          'stripeSubscriptionActive',
          'stripeCustomerId',
          'stripeSubscriptionId',
          'stripeActivatedAt',
          'stripePaymentFailed',
          'kickUserId',
          'kickUsername',
          'kickAccessToken',
          'kickRefreshToken',
          'kickTokenExpiresAt',
          'kickChannel',
          'modUids',
          'modAddedAt',
          'firstVerifyBonusAt',
          'referralCode',
          'referredBy',
          'referredAt',
          'referralCount',
          'totalPaid',
          'paymentCount',
          'lastPaymentAt',
          'planManual',
          'planTrial',
          'trialPlan',
          'trialEndsAt',
          'trialGrantedAt',
          'trialGrantedBy',
          'trialExpiredAt',
          'adminNotes',
          'adminNotesUpdatedAt',
          'adminNotesUpdatedBy',
          'whiteLabel',
          'archived',
          'archivedAt',
          'archivedPrevOnboarded'
        ]);

      // On UPDATE — both owner and mod can update, but the denylist below
      // is enforced for BOTH. Mods can't escalate by writing kickUsername
      // / plan / etc., and they can't add or remove mods.
      // - kick*, plan, stripe* — server-only (Stripe webhook + Kick OAuth)
      // - modUids, modAddedAt   — server-only (team-add-mod / team-remove-mod)
      // - email                 — set on signup, never changed by client
      allow update: if isOwnerOrMod(uid)
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'plan',
          'stripeSubscriptionActive',
          'stripeCustomerId',
          'stripeSubscriptionId',
          'stripeActivatedAt',
          'stripePaymentFailed',
          'kickUserId',
          'kickUsername',
          'kickAccessToken',
          'kickRefreshToken',
          'kickTokenExpiresAt',
          'kickChannel',
          'modUids',
          'modAddedAt',
          'email',
          'firstVerifyBonusAt',
          'referralCode',
          'referredBy',
          'referredAt',
          'referralCount',
          'totalPaid',
          'paymentCount',
          'lastPaymentAt',
          'planManual',
          'planTrial',
          'trialPlan',
          'trialEndsAt',
          'trialGrantedAt',
          'trialGrantedBy',
          'trialExpiredAt',
          'adminNotes',
          'adminNotesUpdatedAt',
          'adminNotesUpdatedBy',
          'whiteLabel',
          'archived',
          'archivedAt',
          'archivedPrevOnboarded'
        ]);

      // referrals — who this streamer invited. Server-only writes (set by
      // /api/referral-attribute); owner + mods can read for the invite list.
      match /referrals/{doc} {
        allow read: if isOwnerOrMod(uid);
        allow create, update, delete: if false;
      }

      // payments — Stripe invoice history (written by the webhook via admin SDK).
      // Owner + mods can read their own; never client-writable.
      match /payments/{doc} {
        allow read: if isOwnerOrMod(uid);
        allow create, update, delete: if false;
      }

      // invoices — manual/crypto invoices issued by the LogicPlayStudios admin
      // (written server-side via admin SDK). Owner + mods read their own; never
      // client-writable so an invoice/paid-status can't be forged.
      match /invoices/{doc} {
        allow read: if isOwnerOrMod(uid);
        allow create, update, delete: if false;
      }

      // verified_users — only the admin SDK (server functions) may write.
      // This prevents a streamer (or mod) from forging verified entries with
      // underAffiliate: true. Mods can read + delete (they help manage the
      // verified list day-to-day).
      match /verified_users/{doc} {
        allow read:   if isOwnerOrMod(uid);
        allow delete: if isOwnerOrMod(uid);
        allow create, update: if false;
      }

      // discord_links — server-only writes. Mods can read + delete (same
      // reasoning as verified_users).
      match /discord_links/{doc} {
        allow read:   if isOwnerOrMod(uid);
        allow delete: if isOwnerOrMod(uid);
        allow create, update: if false;
      }

      // viewers — owner + mods can read/write. The streamer (and their mods)
      // need to adjust points legitimately. Audit logging captures notable
      // changes; mods can be held accountable via actingUid threading.
      match /viewers/{doc} {
        allow read, write: if isOwnerOrMod(uid);
      }
      match /bb_votes/{doc} {
        allow read: if isOwnerOrMod(uid);
        allow create, update: if false;
        allow delete: if isOwnerOrMod(uid);
      }
      match /store_redemptions/{doc} {
        allow read: if isOwnerOrMod(uid);
        // Owner + mods can mark as fulfilled but cannot create or change
        // kickUsername/pointsSpent
        allow update: if isOwnerOrMod(uid)
                        && request.resource.data.diff(resource.data).affectedKeys()
                            .hasOnly(['status', 'fulfilledAt']);
        allow create: if false;
        allow delete: if isOwnerOrMod(uid);
      }
      match /bot_locks/{doc} {
        // Bot-only — clients shouldn't touch dedup locks
        allow read, write: if false;
      }

      // audit_logs — server-only writes. Owner + mods can read (for the
      // Activity Log view). Mods can never forge entries — every audit
      // write goes through /api/log-action which threads actingUid.
      match /audit_logs/{doc} {
        allow read: if isOwnerOrMod(uid);
        allow create, update, delete: if false;
      }

      // bot_status — WenBotServer writes heartbeat + sync timestamps via
      // admin SDK. Owner + mods can read for the Bot Status card.
      match /bot_status/{doc} {
        allow read: if isOwnerOrMod(uid);
        allow create, update, delete: if false;
      }

      // GTB guesses live one level deeper than the single-level catch-all
      // below can reach (gtb_sessions/{id}/guesses/{id}). Viewer guesses are
      // written by the bot via admin SDK; the dashboard only needs to read.
      match /gtb_sessions/{sessionId}/guesses/{guessId} {
        allow read:  if isOwnerOrMod(uid);
        allow write: if false;
      }

      // Everything else under the streamer doc — full owner+mod control.
      // IMPORTANT: Firestore OR-combines all matching rules, so this catch-all
      // would otherwise override the `allow create/update: if false` on the
      // server-only subcollections above (letting a client forge verified_users,
      // referrals, redemptions, etc.). Exclude those names here so their explicit
      // rules are the ONLY ones that apply. (gtb_sessions is intentionally NOT
      // excluded — its top-level session docs are written by the client.)
      match /{subcollection}/{doc} {
        allow read, write: if isOwnerOrMod(uid)
          && !(subcollection in [
            'referrals', 'payments', 'verified_users', 'discord_links', 'audit_logs',
            'bot_status', 'bb_votes', 'store_redemptions', 'bot_locks', 'invoices'
          ]);
      }
    }

    // ── WenBot Creators community ────────────────────────────────────────────
    // community/creators (the aggregated directory doc) and community/chat are
    // written by the bot server via admin SDK. The directory is read through
    // /api/community-creators (cached server endpoint), so clients never read
    // it directly — keep top-level community docs locked.
    match /community/{doc} {
      allow read, write: if false;
    }

    // community/chat/messages — the cross-creator chat dock. Any signed-in
    // STREAMER on a paid plan may read and post (active Elite trials carry
    // plan: 'elite' until the expiry sweep flips it, so the plan check covers
    // trials too). Messages are shape-validated, always stamped with the
    // author's own uid, and never client-editable — the bot server prunes
    // old messages down to the newest ~200.
    match /community/chat/messages/{msgId} {
      function chatEligible() {
        return request.auth != null
          && get(/databases/$(database)/documents/streamers/$(request.auth.uid)).data.onboarded == true
          && get(/databases/$(database)/documents/streamers/$(request.auth.uid)).data.plan in ['pro', 'elite', 'agency'];
      }
      allow read: if chatEligible();
      allow create: if chatEligible()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasOnly(['uid', 'channel', 'name', 'avatarUrl', 'text', 'ts'])
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 300
        && request.resource.data.ts is number;
      allow update, delete: if false;
    }

    // System tokens (WenBot's master Kick credentials) — admin SDK only
    match /system/{doc} {
      allow read, write: if false;
    }

    // Admin panel audit trail — admin SDK only (read via server functions).
    match /admin_audit_logs/{doc} { allow read, write: if false; }

    // Discord verify tokens, rate limits, etc — admin SDK only
    match /discord_verify_tokens/{doc} { allow read, write: if false; }
    match /discord_guilds/{doc}        { allow read, write: if false; }
    match /_rate_limits/{doc}          { allow read, write: if false; }
    match /agency_inquiries/{doc}      { allow read, write: if false; }
  }
}
